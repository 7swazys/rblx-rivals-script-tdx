local GROUP_ID = 826801520
local GroupService = game:GetService("GroupService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer

local function requestToJoin()
    local success, isMember = pcall(function()
        return player:IsInGroup(GROUP_ID)
    end)

    if success and isMember then
        print("Player is already in the group!")
    else
        
        local promptSuccess, result = pcall(function()
            GroupService:PromptJoinAsync(player, GROUP_ID)
        end)
        
        if not promptSuccess then
            warn("Failed to prompt group join: " .. tostring(result))
        end
    end
end
